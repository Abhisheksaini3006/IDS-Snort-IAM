# LOCAL RULES
alert icmp any any -> any any (msg:"ICMP Ping Attack"; sid:1000001;)
alert tcp any any -> any 22 (msg:"SSH Attempt"; sid:1000002;)
alert tcp any any -> any 80 (msg:"HTTP Access"; sid:1000003;)
